{
  "version": 2,
  "builds": [{ "src": "index.html", "use": "@vercel/static-build" }],
  "routes": [
    {
      "src": "/(assets/.*|favicon\\.ico|robots\\.txt|site\\.webmanifest|manifest\\.json|apple-touch-icon\\.png)",
      "dest": "/$1"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}